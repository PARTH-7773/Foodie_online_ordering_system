{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js", 
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/app.js" 
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
